# Foxhound Environment Variables
# Copy to .env and fill in your values

# Proxy configuration (required for protected sites)
# Supports: http://user:pass@host:port, socks5://user:pass@host:port
# Also: host:port:user:pass, protocol:host:port:user:pass
FOXHOUND_PROXY=

# CAPTCHA solver (optional — for reCAPTCHA/hCaptcha/Turnstile)
# Providers: capsolver, twocaptcha
FOXHOUND_CAPTCHA_PROVIDER=
FOXHOUND_CAPTCHA_API_KEY=

# Database export (optional)
FOXHOUND_EXPORT_DB=postgres://user:pass@localhost:5432/foxhound

# Proxy provider API keys (optional)
BRIGHTDATA_API_KEY=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
SMARTPROXY_USERNAME=
SMARTPROXY_PASSWORD=

# Docker compose overrides
POSTGRES_PASSWORD=foxhound
GRAFANA_PASSWORD=admin

# Logging
FOXHOUND_LOG_LEVEL=info
